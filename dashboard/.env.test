# .env.test - NON-SECRET placeholders for the hermetic Playwright suite.
# The suite fakes every network boundary via tests/fixtures/mockBackend.js, so it
# needs zero real credentials. These values exist only so that a *missed* mock
# fails closed (dead endpoint) instead of silently reaching production.
#
# principal: Teable (read-only). 127.0.0.1:9 is the discard port: any un-mocked
# Teable call fails closed instead of hitting a real instance.
VITE_TEABLE_URL=http://127.0.0.1:9
VITE_TEABLE_TOKEN=test-teable-token-DO-NOT-USE-REAL
VITE_TEABLE_TABLE_ID=tbltest0000000000
# The Brands/Kingdom tab (the old gen.aditor.ai backend calls) was removed in 2026-07,
# so the Teable read above is now the app's only network boundary.
